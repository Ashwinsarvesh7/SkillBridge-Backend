# Copy this file to application-local.properties and configure for your local environment
# application-local.properties is loaded automatically by Spring Boot if it exists and is NOT committed to version control

# Select which database profile to use (mysql or postgres)
# spring.profiles.active=mysql

# MySQL Local Development (used if spring.profiles.active=mysql or not specified)
spring.datasource.username=root
spring.datasource.password=Ashwin@1512
spring.datasource.url=jdbc:mysql://localhost:3306/skillbridge_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

# PostgreSQL (uncomment and configure if spring.profiles.active=postgres)
# spring.datasource.username=skillbridge
# spring.datasource.password=YOUR_POSTGRES_PASSWORD
# spring.datasource.url=jdbc:postgresql://localhost:5432/skillbridge_db

# JWT Configuration
skillbridge.jwt.secret=SkillBridgeSecretKeyForJWTTokenGenerationMustBeAtLeast256BitsLong2026

# Mail Configuration (optional)
# skillbridge.mail.enabled=true
# spring.mail.username=your-email@gmail.com
# spring.mail.password=your-app-password
